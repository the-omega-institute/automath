import Mathlib.Tactic

namespace Omega.POM

open scoped BigOperators

/-- The finite oracle-capacity curve generated by a multiplicity profile. -/
def pom_oracle_capacity_kinks_slopes_capacity {X : Type*} [Fintype X] (d : X → ℕ)
    (u : ℕ) : ℤ :=
  ∑ x : X, (Nat.min (d x) u : ℤ)

/-- Tail count of fibers whose multiplicity is still above the current budget. -/
def pom_oracle_capacity_kinks_slopes_tail {X : Type*} [Fintype X] (d : X → ℕ)
    (u : ℕ) : ℕ :=
  (Finset.univ.filter fun x : X => u < d x).card

/-- Multiplicity histogram at one finite level. -/
def pom_oracle_capacity_kinks_slopes_multiplicity {X : Type*} [Fintype X] (d : X → ℕ)
    (k : ℕ) : ℕ :=
  (Finset.univ.filter fun x : X => d x = k).card

private lemma pom_oracle_capacity_kinks_slopes_min_step (d u : ℕ) :
    (Nat.min d (u + 1) : ℤ) - (Nat.min d u : ℤ) = if u < d then 1 else 0 := by
  by_cases h : u < d
  · have hu0 : (Nat.min d u : ℤ) = u := by
      exact_mod_cast Nat.min_eq_right h.le
    simp [h, hu0]
  · have hd : d ≤ u := le_of_not_gt h
    simp [Nat.min_eq_left hd, Nat.min_eq_left (le_trans hd (Nat.le_succ u)), h]

private lemma pom_oracle_capacity_kinks_slopes_sum_indicator {X : Type*} [Fintype X]
    (p : X → Prop) [DecidablePred p] :
    (∑ x : X, if p x then (1 : ℤ) else 0) =
      ((Finset.univ.filter fun x : X => p x).card : ℤ) := by
  rw [← Finset.sum_filter]
  simp

private lemma pom_oracle_capacity_kinks_slopes_tail_step_indicator (k d : ℕ) :
    (if k < d then (1 : ℤ) else 0) - (if k + 1 < d then (1 : ℤ) else 0) =
      if d = k + 1 then 1 else 0 := by
  by_cases hEq : d = k + 1
  · simp [hEq]
  · by_cases hlt : k + 1 < d
    · have hk : k < d := by omega
      simp [hEq, hlt, hk]
    · have hk : ¬ k < d := by omega
      simp [hEq, hlt, hk]

/-- Paper label: `cor:pom-oracle-capacity-kinks-slopes`. For a finite multiplicity profile, the
unit increment of the capacity curve is exactly the tail count, and consecutive tail differences
recover the multiplicity histogram, i.e. the slope jumps occur exactly at the multiplicities. -/
theorem paper_pom_oracle_capacity_kinks_slopes {X : Type*} [Fintype X] (d : X → ℕ) :
    (∀ u : ℕ,
        pom_oracle_capacity_kinks_slopes_capacity d (u + 1) -
            pom_oracle_capacity_kinks_slopes_capacity d u =
          (pom_oracle_capacity_kinks_slopes_tail d u : ℤ)) ∧
      ∀ k : ℕ,
        (pom_oracle_capacity_kinks_slopes_tail d k : ℤ) -
            (pom_oracle_capacity_kinks_slopes_tail d (k + 1) : ℤ) =
          (pom_oracle_capacity_kinks_slopes_multiplicity d (k + 1) : ℤ) := by
  classical
  refine ⟨?_, ?_⟩
  · intro u
    calc
      pom_oracle_capacity_kinks_slopes_capacity d (u + 1) -
          pom_oracle_capacity_kinks_slopes_capacity d u
          = ∑ x : X, ((Nat.min (d x) (u + 1) : ℤ) - (Nat.min (d x) u : ℤ)) := by
              simp [pom_oracle_capacity_kinks_slopes_capacity, Finset.sum_sub_distrib]
      _ = ∑ x : X, if u < d x then (1 : ℤ) else 0 := by
              refine Finset.sum_congr rfl ?_
              intro x _hx
              exact pom_oracle_capacity_kinks_slopes_min_step (d x) u
      _ = (pom_oracle_capacity_kinks_slopes_tail d u : ℤ) := by
              rw [pom_oracle_capacity_kinks_slopes_sum_indicator]
              rfl
  · intro k
    calc
      (pom_oracle_capacity_kinks_slopes_tail d k : ℤ) -
          (pom_oracle_capacity_kinks_slopes_tail d (k + 1) : ℤ)
          = (∑ x : X, if k < d x then (1 : ℤ) else 0) -
              ∑ x : X, if k + 1 < d x then (1 : ℤ) else 0 := by
              unfold pom_oracle_capacity_kinks_slopes_tail
              rw [pom_oracle_capacity_kinks_slopes_sum_indicator,
                pom_oracle_capacity_kinks_slopes_sum_indicator]
      _ = ∑ x : X,
              ((if k < d x then (1 : ℤ) else 0) -
                (if k + 1 < d x then (1 : ℤ) else 0)) := by
              rw [Finset.sum_sub_distrib]
      _ = ∑ x : X, if d x = k + 1 then (1 : ℤ) else 0 := by
              refine Finset.sum_congr rfl ?_
              intro x _hx
              exact pom_oracle_capacity_kinks_slopes_tail_step_indicator k (d x)
      _ = (pom_oracle_capacity_kinks_slopes_multiplicity d (k + 1) : ℤ) := by
              rw [pom_oracle_capacity_kinks_slopes_sum_indicator]
              rfl

end Omega.POM
