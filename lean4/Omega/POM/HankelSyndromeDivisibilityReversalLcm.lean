import Mathlib.Data.Nat.Factorization.Basic
import Mathlib.Tactic

namespace Omega.POM

/-- Arithmetic proxy for the truncated multiple module generated by a recurrence divisor. -/
def pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set (d : ℕ) : Set ℕ :=
  {n | d ∣ n}

/-- Paper label: `prop:pom-hankel-syndrome-divisibility-reversal-lcm`.

For the concrete arithmetic proxy of truncated multiples, divisibility reverses inclusion of
multiple-sets, and the common multiples are exactly the multiples of the `lcm`. -/
theorem paper_pom_hankel_syndrome_divisibility_reversal_lcm {a b : ℕ} :
    (a ∣ b ↔
      pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set b ⊆
        pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set a) ∧
    pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set a ∩
        pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set b =
      pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set (Nat.lcm a b) := by
  constructor
  · constructor
    · intro hab n hn
      exact dvd_trans hab hn
    · intro hSubset
      exact hSubset (dvd_rfl : b ∣ b)
  · ext n
    simp [pom_hankel_syndrome_divisibility_reversal_lcm_multiple_set, Nat.lcm_dvd_iff]

end Omega.POM
