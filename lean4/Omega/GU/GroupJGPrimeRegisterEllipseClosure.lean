import Omega.GU.GroupJGPrimeRegisterPhaseBohrDense
import Omega.GU.JoukowskyAreaPreservingCayley
import Mathlib.Tactic

namespace Omega.GU

/-- The Bohr-dense phase orbit generated by the two prime logarithms. -/
noncomputable def primeRegisterPhaseOrbit (t : ℝ) : Set ℝ :=
  (AddSubgroup.closure {t * Real.log (2 : ℝ), t * Real.log (3 : ℝ)} : Set ℝ)

/-- A concrete code for the normalized Joukowsky ellipse layer at parameter `u`. The first
coordinate records the phase, while the remaining coordinates encode the major and minor axes. -/
noncomputable def joukowskyEllipseLayer (u : ℝ) : ℝ × ℝ × ℝ :=
  (u, (2 * Real.cosh u, 2 * Real.sinh u))

/-- Every normalized ellipse layer is contained in the closure of the prime-register orbit image. -/
def primeRegisterEllipseFullClosure (t : ℝ) : Prop :=
  Set.range joukowskyEllipseLayer ⊆ closure (joukowskyEllipseLayer '' primeRegisterPhaseOrbit t)

/-- The degenerate layer `u = 0` belongs to the closure of the prime-register ellipse family. -/
def primeRegisterDegenerateLayerInClosure (t : ℝ) : Prop :=
  joukowskyEllipseLayer 0 ∈ closure (joukowskyEllipseLayer '' primeRegisterPhaseOrbit t)

/-- The only layer with vanishing minor semiaxis is the degenerate layer `u = 0`. -/
def primeRegisterUniqueDegenerateLayer : Prop :=
  ∀ u, (joukowskyEllipseLayer u).2.2 = 0 → u = 0

private lemma continuous_joukowskyEllipseLayer : Continuous joukowskyEllipseLayer := by
  unfold joukowskyEllipseLayer
  continuity

/-- The Joukowsky ellipse family obtained from the prime-register phase subgroup is dense in the
full normalized ellipse family; in particular the degenerate layer lies in the closure, and it is
the unique layer with vanishing minor semiaxis.
    thm:group-jg-prime-register-ellipse-closure -/
theorem paper_group_jg_prime_register_ellipse_closure (t : ℝ) (ht : t ≠ 0) :
    primeRegisterEllipseFullClosure t ∧
      primeRegisterDegenerateLayerInClosure t ∧
      primeRegisterUniqueDegenerateLayer := by
  have hdense : Dense (primeRegisterPhaseOrbit t) := by
    simpa [primeRegisterPhaseOrbit] using
      paper_group_jg_prime_register_phase_bohr_dense ⟨t, ht⟩
  have hfull : primeRegisterEllipseFullClosure t := by
    intro y hy
    rcases hy with ⟨u, rfl⟩
    exact continuous_joukowskyEllipseLayer.range_subset_closure_image_dense hdense
      (Set.mem_range_self u)
  refine ⟨?_, ?_, ?_⟩
  · exact hfull
  · exact hfull (Set.mem_range_self 0)
  · intro u hu
    have hsinh : Real.sinh u = 0 := by
      simpa [joukowskyEllipseLayer] using hu
    exact Real.sinh_eq_zero.mp hsinh

/-- The degenerate normalized Joukowsky layer lies in the closure of the two-prime register
ellipse family.
    cor:group-jg-prime-register-degenerate-approx -/
theorem paper_group_jg_prime_register_degenerate_approx (t : ℝ) (ht : t ≠ 0) :
    primeRegisterDegenerateLayerInClosure t := by
  exact (paper_group_jg_prime_register_ellipse_closure t ht).2.1

end Omega.GU
