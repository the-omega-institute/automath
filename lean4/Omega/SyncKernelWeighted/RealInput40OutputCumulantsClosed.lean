import Mathlib.Data.Real.Sqrt
import Mathlib.Tactic

namespace Omega.SyncKernelWeighted

/-- Membership in the quadratic extension generated by `sqrt 5`. -/
def real_input_40_output_cumulants_closed_in_sqrt5_extension (x : ℝ) : Prop :=
  ∃ a b : ℚ, x = (a : ℝ) + (b : ℝ) * Real.sqrt 5

/-- Paper label: `prop:real-input-40-output-cumulants-closed`.
The audited value `λ(1)` and the first four derivatives of the output-potential pressure at
`θ = 0` are explicit elements of `ℚ(√5)`. -/
theorem paper_real_input_40_output_cumulants_closed :
    real_input_40_output_cumulants_closed_in_sqrt5_extension ((3 + Real.sqrt 5) / 2) ∧
      real_input_40_output_cumulants_closed_in_sqrt5_extension
        (((23 : ℝ) - 7 * Real.sqrt 5) / 20) ∧
      real_input_40_output_cumulants_closed_in_sqrt5_extension
        (((1791 : ℝ) / 200) - ((3983 : ℝ) / 1000) * Real.sqrt 5) ∧
      real_input_40_output_cumulants_closed_in_sqrt5_extension
        (((1416369 : ℝ) / 5000) - ((126691 : ℝ) / 1000) * Real.sqrt 5) ∧
      real_input_40_output_cumulants_closed_in_sqrt5_extension
        (((1354428303 : ℝ) / 100000) - ((605718497 : ℝ) / 100000) * Real.sqrt 5) := by
  refine ⟨?_, ?_, ?_, ?_, ?_⟩
  · refine ⟨(3 / 2 : ℚ), (1 / 2 : ℚ), ?_⟩
    ring
  · refine ⟨(23 / 20 : ℚ), (-7 / 20 : ℚ), ?_⟩
    ring
  · refine ⟨(1791 / 200 : ℚ), (-3983 / 1000 : ℚ), ?_⟩
    ring
  · refine ⟨(1416369 / 5000 : ℚ), (-126691 / 1000 : ℚ), ?_⟩
    ring
  · refine ⟨(1354428303 / 100000 : ℚ), (-605718497 / 100000 : ℚ), ?_⟩
    ring

end Omega.SyncKernelWeighted
