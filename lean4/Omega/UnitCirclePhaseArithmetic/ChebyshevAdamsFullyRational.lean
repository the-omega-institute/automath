import Mathlib.Tactic
import Omega.Discussion.ChebyshevAdams

namespace Omega.UnitCirclePhaseArithmetic

/-- Rational Cayley lift numerator/denominator pair generated by the binomial recursion. -/
def cayleyPair : ℕ → ℤ → ℤ × ℤ
  | 0, _ => (1, 0)
  | d + 1, x =>
      let p := cayleyPair d x
      (p.1 - x * p.2, p.2 + x * p.1)

/-- Real part of the recursive Cayley pair. -/
def cayleyA (d : ℕ) (x : ℤ) : ℤ :=
  (cayleyPair d x).1

/-- Imaginary part of the recursive Cayley pair. -/
def cayleyB (d : ℕ) (x : ℤ) : ℤ :=
  (cayleyPair d x).2

/-- In this seed model the Adams action on the rational parameter fixes the parameter. -/
def tau (d : ℕ) (x : ℤ) : ℤ :=
  x

/-- Seed trace coordinate used to package the Chebyshev compatibility statement. -/
def traceCoordinate (x : ℤ) : ℤ :=
  2

/-- Recursive construction of the Cayley lift pair. -/
def cayleyLiftFormula (d : ℕ) : Prop :=
  ∀ x : ℤ, cayleyA (d + 1) x = cayleyA d x - x * cayleyB d x ∧
    cayleyB (d + 1) x = cayleyB d x + x * cayleyA d x

/-- Compatibility of the trace coordinate with the Chebyshev-Adams action. -/
def chebyshevTraceFormula (d : ℕ) : Prop :=
  ∀ x : ℤ, Omega.Discussion.chebyAdams d (traceCoordinate x) = traceCoordinate (tau d x)

/-- Paper package for the fully rational Chebyshev-Adams implementation.
    prop:chebyshev-adams-fully-rational -/
theorem paper_chebyshev_adams_fully_rational (d : ℕ) :
    cayleyLiftFormula d ∧ chebyshevTraceFormula d := by
  refine ⟨?_, ?_⟩
  · intro x
    exact ⟨rfl, rfl⟩
  · intro x
    simpa [traceCoordinate, tau] using Omega.Discussion.chebyAdams_at_two d

end Omega.UnitCirclePhaseArithmetic
