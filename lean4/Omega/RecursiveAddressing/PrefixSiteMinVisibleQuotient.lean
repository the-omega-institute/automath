import Mathlib.GroupTheory.QuotientGroup.Basic
import Mathlib.Tactic

namespace Omega.RecursiveAddressing

/-- The additive subgroup generated by all cocycle values that occur on nonempty triple overlaps.
    prop:prefix-site-min-visible-quotient -/
def visibleObstructionSubgroup
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop) : AddSubgroup A :=
  AddSubgroup.closure {a | ∃ i j k, nonemptyTriple i j k ∧ α i j k = a}

/-- The visible quotient obtained by killing the subgroup generated by the visible cocycle values.
    prop:prefix-site-min-visible-quotient -/
abbrev VisibleQuotient
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop) :=
  A ⧸ visibleObstructionSubgroup α nonemptyTriple

/-- The canonical projection to the visible quotient.
    prop:prefix-site-min-visible-quotient -/
abbrev visibleProjection
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop) :
    A →+ VisibleQuotient α nonemptyTriple :=
  QuotientAddGroup.mk' (visibleObstructionSubgroup α nonemptyTriple)

lemma cocycle_mem_visibleObstructionSubgroup
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop)
    {i j k : ι} (hijk : nonemptyTriple i j k) :
    α i j k ∈ visibleObstructionSubgroup α nonemptyTriple := by
  exact AddSubgroup.subset_closure ⟨i, j, k, hijk, rfl⟩

set_option maxHeartbeats 400000 in
/-- Paper-facing visible-quotient package: the quotient by the subgroup generated by the visible
    triple-overlap cocycle values kills the cocycle pointwise, and it is initial among coefficient
    maps with that vanishing property.
    prop:prefix-site-min-visible-quotient -/
theorem paper_recursive_addressing_prefix_site_min_visible_quotient
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop) :
    (∀ i j k, nonemptyTriple i j k →
      visibleProjection α nonemptyTriple (α i j k) = 0) ∧
    ∀ {B : Type*} [AddCommGroup B] (φ : A →+ B),
      (∀ i j k, nonemptyTriple i j k → φ (α i j k) = 0) →
      ∃! φbar : VisibleQuotient α nonemptyTriple →+ B,
        φbar.comp (visibleProjection α nonemptyTriple) = φ := by
  constructor
  · intro i j k hijk
    simpa [visibleProjection] using
      (QuotientAddGroup.eq_zero_iff (α i j k)).2
      (cocycle_mem_visibleObstructionSubgroup α nonemptyTriple hijk)
  · intro B _ φ hkill
    have hker : visibleObstructionSubgroup α nonemptyTriple ≤ φ.ker := by
      refine (AddSubgroup.closure_le _).2 ?_
      rintro a ⟨i, j, k, hijk, rfl⟩
      show φ (α i j k) = 0
      exact hkill i j k hijk
    let φbar : VisibleQuotient α nonemptyTriple →+ B :=
      QuotientAddGroup.lift (visibleObstructionSubgroup α nonemptyTriple) φ hker
    have hφbar : φbar.comp (visibleProjection α nonemptyTriple) = φ := by
      simpa [φbar, visibleProjection] using
        (QuotientAddGroup.lift_comp_mk' (visibleObstructionSubgroup α nonemptyTriple) φ hker)
    refine ⟨φbar, ?_, ?_⟩
    · exact hφbar
    · intro ψ hψ
      ext q
      obtain ⟨a, ha⟩ :=
        QuotientAddGroup.mk'_surjective (visibleObstructionSubgroup α nonemptyTriple) q
      have hψa : ψ (visibleProjection α nonemptyTriple a) = φ a := by
        simpa using congrArg (fun f : A →+ B => f a) hψ
      have hφbara : φbar (visibleProjection α nonemptyTriple a) = φ a := by
        simpa using congrArg (fun f : A →+ B => f a) hφbar
      calc
        ψ q = ψ (visibleProjection α nonemptyTriple a) := by rw [ha.symm]
        _ = φ a := hψa
        _ = φbar (visibleProjection α nonemptyTriple a) := hφbara.symm
        _ = φbar q := by rw [ha.symm]

set_option maxHeartbeats 400000 in
/-- Lower-case theorem name matching the round target: the visible quotient kills every triple
    overlap cocycle value and is initial among coefficient maps with that vanishing property.
    prop:prefix-site-min-visible-quotient -/
theorem paper_prefix_site_min_visible_quotient
    {ι A : Type*} [AddCommGroup A]
    (α : ι → ι → ι → A) (nonemptyTriple : ι → ι → ι → Prop) :
    (∀ i j k, nonemptyTriple i j k →
      visibleProjection α nonemptyTriple (α i j k) = 0) ∧
    ∀ {B : Type*} [AddCommGroup B] (φ : A →+ B),
      (∀ i j k, nonemptyTriple i j k → φ (α i j k) = 0) →
      ∃! φbar : VisibleQuotient α nonemptyTriple →+ B,
        φbar.comp (visibleProjection α nonemptyTriple) = φ := by
  exact paper_recursive_addressing_prefix_site_min_visible_quotient α nonemptyTriple

namespace PointwiseInvisible

section

variable {ι A B : Type*} [AddCommGroup A] [AddCommGroup B]

/-- The subgroup generated by the cocycle values that must be annihilated to make the obstruction
pointwise invisible. -/
def cocycleValueSubgroup (α : ι → A) : AddSubgroup A :=
  AddSubgroup.closure (Set.range α)

/-- The visible quotient obtained by killing the subgroup generated by the cocycle values. -/
abbrev VisibleQuotient (α : ι → A) :=
  A ⧸ cocycleValueSubgroup α

lemma cocycleValueSubgroup_le_ker (α : ι → A) (φ : A →+ B) (hφ : ∀ i, φ (α i) = 0) :
    cocycleValueSubgroup α ≤ φ.ker := by
  rw [cocycleValueSubgroup, AddSubgroup.closure_le]
  rintro _ ⟨i, rfl⟩
  simpa [AddMonoidHom.mem_ker] using hφ i

/-- Paper-facing minimal visible quotient: quotient by the subgroup generated by the cocycle
values, so every cocycle entry vanishes in the quotient, and every homomorphism annihilating those
entries factors uniquely through that quotient.
    prop:prefix-site-min-visible-quotient -/
theorem paper_recursive_addressing_prefix_site_min_visible_quotient
    (α : ι → A) :
    (∀ i, (QuotientAddGroup.mk' (cocycleValueSubgroup α)) (α i) = 0) ∧
      ∀ φ : A →+ B, (∀ i, φ (α i) = 0) →
        ∃! φvis : VisibleQuotient α →+ B,
          φvis.comp (QuotientAddGroup.mk' (cocycleValueSubgroup α)) = φ := by
  constructor
  · intro i
    exact
      (QuotientAddGroup.eq_zero_iff (α i)).2 <|
        AddSubgroup.subset_closure ⟨i, rfl⟩
  · intro φ hφ
    have hker : cocycleValueSubgroup α ≤ φ.ker :=
      cocycleValueSubgroup_le_ker α φ hφ
    have hlift :
        (QuotientAddGroup.lift (cocycleValueSubgroup α) φ hker).comp
            (QuotientAddGroup.mk' (cocycleValueSubgroup α)) = φ := by
      ext a
      simp
    refine ⟨QuotientAddGroup.lift (cocycleValueSubgroup α) φ hker, hlift, ?_⟩
    intro ψ hψ
    apply QuotientAddGroup.addMonoidHom_ext
    rw [hψ, hlift]

end

end PointwiseInvisible

/-- Concrete counterexample showing why the requested wrapper statement is unprovable from only a
surjective `pi` and pointwise vanishing on the listed `alpha`-generators: `phi = Prod.snd` kills
`alpha = 0`, but it is not constant on the fibers of `pi = Prod.fst`. -/
theorem paper_recursive_addressing_prefix_site_min_visible_quotient_counterexample :
    let pi : Nat × Nat → Nat := fun x => x.1
    let alpha : Unit → Nat × Nat := fun _ => (0, 0)
    (∀ i, pi (alpha i) = 0) ∧
      (∀ i, (fun x : Nat × Nat => x.2) (alpha i) = 0) ∧
      ¬ ∃! phiVis : Nat → Nat, (fun x : Nat × Nat => x.2) = phiVis ∘ pi := by
  let pi : Nat × Nat → Nat := fun x => x.1
  let alpha : Unit → Nat × Nat := fun _ => (0, 0)
  refine ⟨?_, ?_, ?_⟩
  · intro i
    rfl
  · intro i
    rfl
  · intro hfactor
    rcases hfactor with ⟨phiVis, hphi, _uniq⟩
    have h00 := congrFun hphi (0, 0)
    have h01 := congrFun hphi (0, 1)
    simp at h00 h01
    omega

end Omega.RecursiveAddressing
