import Mathlib.Topology.Closure
import Omega.Conclusion.JGGodelDenseOrbitsOnHyperbolaLeaf

namespace Omega.Conclusion

/-- The discrete orbit on the `θ`-leaf generated by the dense logarithmic lattice. -/
def conclusion_leyang_godel_hyperbola_orbit_closure_orbitSet (θ : ℝ) : Set ℂ :=
  conclusion_two_prime_dense_orbit_hyperbola_leaf_log_point θ ''
    conclusion_two_prime_dense_orbit_hyperbola_leaf_log_lattice

/-- The full `θ`-leaf written as the range of the logarithmic parametrization. -/
def conclusion_leyang_godel_hyperbola_orbit_closure_leafSet (θ : ℝ) : Set ℂ :=
  Set.range (conclusion_two_prime_dense_orbit_hyperbola_leaf_log_point θ)

/-- Paper label: `thm:conclusion-leyang-godel-hyperbola-orbit-closure`. For each angle the
existing two-prime dense-orbit package makes the logarithmic-lattice image dense in the
corresponding hyperbola leaf, and finite-union closure then identifies the closure of the whole
finite orbit family with the closure of the union of those leaves. -/
theorem paper_conclusion_leyang_godel_hyperbola_orbit_closure
    (N : ℕ) (θ : Fin N → ℝ)
    (hθ : ∀ j, Real.sin (θ j) * Real.cos (θ j) ≠ 0) :
    (∀ j,
      conclusion_leyang_godel_hyperbola_orbit_closure_leafSet (θ j) ⊆
        closure (conclusion_leyang_godel_hyperbola_orbit_closure_orbitSet (θ j))) ∧
      closure (⋃ j, conclusion_leyang_godel_hyperbola_orbit_closure_orbitSet (θ j)) =
        closure (⋃ j, conclusion_leyang_godel_hyperbola_orbit_closure_leafSet (θ j)) := by
  have hbase := paper_conclusion_two_prime_dense_orbit_hyperbola_leaf
  have horbit_dense :
      ∀ j,
        conclusion_leyang_godel_hyperbola_orbit_closure_leafSet (θ j) ⊆
          closure (conclusion_leyang_godel_hyperbola_orbit_closure_orbitSet (θ j)) := by
    intro j
    have hcont :
        Continuous (conclusion_two_prime_dense_orbit_hyperbola_leaf_log_point (θ j)) :=
      (hbase.2 (θ j) (hθ j)).1
    simpa [conclusion_leyang_godel_hyperbola_orbit_closure_orbitSet,
      conclusion_leyang_godel_hyperbola_orbit_closure_leafSet, Set.image_eq_range] using
      hcont.range_subset_closure_image_dense hbase.1
  refine ⟨horbit_dense, ?_⟩
  apply le_antisymm
  · apply closure_mono
    intro z hz
    rw [Set.mem_iUnion] at hz ⊢
    rcases hz with ⟨j, hjz⟩
    refine ⟨j, ?_⟩
    rcases hjz with ⟨x, hx, rfl⟩
    exact ⟨x, rfl⟩
  · apply closure_minimal
    · intro z hz
      rw [Set.mem_iUnion] at hz
      rcases hz with ⟨j, hjz⟩
      exact closure_mono (by
        intro w hw
        rw [Set.mem_iUnion]
        exact ⟨j, hw⟩) (horbit_dense j hjz)
    · exact isClosed_closure

end Omega.Conclusion
