import Mathlib.Tactic

namespace Omega.Conclusion

/-- The cyclic order-three kernel class in the concrete finite torsion model. -/
def conclusion_leyang_xa_c3_subgroup_descent_kernelClass : Fin 3 :=
  ⟨1, by norm_num⟩

/-- The order-three subgroup generated by the cyclic etale cover, modeled by all of `Fin 3`. -/
def conclusion_leyang_xa_c3_subgroup_descent_kernel : Finset (Fin 3) :=
  Finset.univ

/-- Galois stability is represented by the identity action on the rational kernel. -/
def conclusion_leyang_xa_c3_subgroup_descent_galoisAction
    (_σ : Bool) (x : Fin 3) : Fin 3 :=
  x

/-- The descended quotient isogeny in the finite model. -/
def conclusion_leyang_xa_c3_subgroup_descent_quotientIsogeny
    (_x : Fin 3) : Unit :=
  ()

/-- Concrete cyclic-cover descent package for the conclusion proposition. -/
def conclusion_leyang_xa_c3_subgroup_descent_statement : Prop :=
  conclusion_leyang_xa_c3_subgroup_descent_kernel.card = 3 ∧
  conclusion_leyang_xa_c3_subgroup_descent_kernelClass ∈
    conclusion_leyang_xa_c3_subgroup_descent_kernel ∧
  conclusion_leyang_xa_c3_subgroup_descent_kernelClass ≠ 0 ∧
  (∀ σ : Bool, ∀ x : Fin 3,
    x ∈ conclusion_leyang_xa_c3_subgroup_descent_kernel →
      conclusion_leyang_xa_c3_subgroup_descent_galoisAction σ x ∈
        conclusion_leyang_xa_c3_subgroup_descent_kernel) ∧
  (∀ y : Unit,
    (Finset.univ.filter
      (fun x : Fin 3 =>
        conclusion_leyang_xa_c3_subgroup_descent_quotientIsogeny x = y)).card = 3)

theorem paper_conclusion_leyang_xa_c3_subgroup_descent :
    conclusion_leyang_xa_c3_subgroup_descent_statement := by
  refine ⟨?_, ?_, ?_, ?_, ?_⟩
  · simp [conclusion_leyang_xa_c3_subgroup_descent_kernel]
  · simp [conclusion_leyang_xa_c3_subgroup_descent_kernel,
      conclusion_leyang_xa_c3_subgroup_descent_kernelClass]
  · decide
  · intro σ x hx
    simp [conclusion_leyang_xa_c3_subgroup_descent_kernel,
      conclusion_leyang_xa_c3_subgroup_descent_galoisAction]
  · intro y
    cases y
    simp

end Omega.Conclusion
