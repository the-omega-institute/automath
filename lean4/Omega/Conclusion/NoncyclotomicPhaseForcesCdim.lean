import Mathlib.Data.Complex.Basic
import Mathlib.Tactic

namespace Omega.Conclusion

/-- Concrete algebraic package for the noncyclotomic phase obstruction. The character is only
used along the cyclic subgroup generated by `sourceElement`; the power law and the value at zero
are enough to turn a non-root-of-unity phase into an infinite-order source witness. -/
structure conclusion_noncyclotomic_phase_forces_cdim_data where
  conclusion_noncyclotomic_phase_forces_cdim_sourceElement : ℤ
  conclusion_noncyclotomic_phase_forces_cdim_character : ℤ → ℂ
  conclusion_noncyclotomic_phase_forces_cdim_character_zero :
    conclusion_noncyclotomic_phase_forces_cdim_character 0 = 1
  conclusion_noncyclotomic_phase_forces_cdim_character_power_law :
    ∀ n : ℕ,
      conclusion_noncyclotomic_phase_forces_cdim_character
          ((n : ℤ) * conclusion_noncyclotomic_phase_forces_cdim_sourceElement) =
        conclusion_noncyclotomic_phase_forces_cdim_character
          conclusion_noncyclotomic_phase_forces_cdim_sourceElement ^ n
  conclusion_noncyclotomic_phase_forces_cdim_phase_nonroot :
    ∀ n : ℕ,
      0 < n →
        conclusion_noncyclotomic_phase_forces_cdim_character
            conclusion_noncyclotomic_phase_forces_cdim_sourceElement ^ n ≠ 1

namespace conclusion_noncyclotomic_phase_forces_cdim_data

/-- The source generator has infinite order in the cyclic subgroup detected by the character. -/
def sourceElementInfiniteOrder
    (D : conclusion_noncyclotomic_phase_forces_cdim_data) : Prop :=
  ∀ n : ℕ,
    0 < n → (n : ℤ) * D.conclusion_noncyclotomic_phase_forces_cdim_sourceElement ≠ 0

/-- Circle-factor rank witnessed by the infinite-order source element. -/
def circleFactorRank (_D : conclusion_noncyclotomic_phase_forces_cdim_data) : ℕ :=
  1

/-- The circle-dimension conclusion recorded by the paper statement. -/
def cdimAtLeastOne (D : conclusion_noncyclotomic_phase_forces_cdim_data) : Prop :=
  D.sourceElementInfiniteOrder ∧ 1 ≤ D.circleFactorRank

end conclusion_noncyclotomic_phase_forces_cdim_data

/-- Paper label: `prop:conclusion-noncyclotomic-phase-forces-cdim`. -/
theorem paper_conclusion_noncyclotomic_phase_forces_cdim
    (D : conclusion_noncyclotomic_phase_forces_cdim_data) : D.cdimAtLeastOne := by
  have hinfinite : D.sourceElementInfiniteOrder := by
    intro n hn hzero
    have hchar_zeroed :
        D.conclusion_noncyclotomic_phase_forces_cdim_character
            ((n : ℤ) * D.conclusion_noncyclotomic_phase_forces_cdim_sourceElement) = 1 := by
      simpa [hzero] using D.conclusion_noncyclotomic_phase_forces_cdim_character_zero
    have hphase :
        D.conclusion_noncyclotomic_phase_forces_cdim_character
            D.conclusion_noncyclotomic_phase_forces_cdim_sourceElement ^ n = 1 := by
      rw [← D.conclusion_noncyclotomic_phase_forces_cdim_character_power_law n]
      exact hchar_zeroed
    exact D.conclusion_noncyclotomic_phase_forces_cdim_phase_nonroot n hn hphase
  exact ⟨hinfinite, by simp [conclusion_noncyclotomic_phase_forces_cdim_data.circleFactorRank]⟩

end Omega.Conclusion
