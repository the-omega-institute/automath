import Mathlib.Tactic
import Omega.Folding.KilloChainInteriorGodelGcdLcm

namespace Omega.Conclusion

open Finset

/-- The order ideal generated by `j` in the finite chain `0 < 1 < ... < r`. -/
def conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment {r : ℕ}
    (j : Fin (r + 1)) : Finset (Fin (r + 1)) :=
  Finset.univ.filter fun i => i ≤ j

lemma conclusion_screen_rt_chain_arithmetic_divisor_shadow_zero_mem {r : ℕ}
    (j : Fin (r + 1)) :
    (0 : Fin (r + 1)) ∈
      conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment j := by
  simp [conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment]

lemma conclusion_screen_rt_chain_arithmetic_divisor_shadow_inter {r : ℕ}
    (i j : Fin (r + 1)) :
    conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment (min i j) =
      conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment i ∩
        conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment j := by
  ext x
  simp [conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment]

lemma conclusion_screen_rt_chain_arithmetic_divisor_shadow_union {r : ℕ}
    (i j : Fin (r + 1)) :
    conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment (max i j) =
      conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment i ∪
        conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment j := by
  ext x
  simp [conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment]

/-- The chain of nested RT cuts embeds into the order ideals of the finite chain, and the
squarefree chain Gödel code turns meet/join on those ideals into `gcd`/`lcm`. -/
def conclusion_screen_rt_chain_arithmetic_divisor_shadow_statement : Prop :=
  ∀ r : ℕ,
    let ι : Fin (r + 1) → Finset (Fin (r + 1)) :=
      conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment
    (∀ i j, ι (min i j) = ι i ∩ ι j) ∧
      (∀ i j, ι (max i j) = ι i ∪ ι j) ∧
      (∀ i j,
        Omega.Folding.chainInteriorGodelCode (ι (min i j)) =
          Nat.gcd (Omega.Folding.chainInteriorGodelCode (ι i))
            (Omega.Folding.chainInteriorGodelCode (ι j))) ∧
      ∀ i j,
        Omega.Folding.chainInteriorGodelCode (ι (max i j)) =
          Nat.lcm (Omega.Folding.chainInteriorGodelCode (ι i))
            (Omega.Folding.chainInteriorGodelCode (ι j))

theorem conclusion_screen_rt_chain_arithmetic_divisor_shadow_verified :
    conclusion_screen_rt_chain_arithmetic_divisor_shadow_statement := by
  intro r
  let ι : Fin (r + 1) → Finset (Fin (r + 1)) :=
    conclusion_screen_rt_chain_arithmetic_divisor_shadow_initialSegment
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro i j
    exact conclusion_screen_rt_chain_arithmetic_divisor_shadow_inter i j
  · intro i j
    exact conclusion_screen_rt_chain_arithmetic_divisor_shadow_union i j
  · intro i j
    have hArithmetic :=
      Omega.Folding.paper_killo_chain_interior_godel_gcd_lcm r (ι i) (ι j)
        (conclusion_screen_rt_chain_arithmetic_divisor_shadow_zero_mem i)
        (conclusion_screen_rt_chain_arithmetic_divisor_shadow_zero_mem j)
    rw [conclusion_screen_rt_chain_arithmetic_divisor_shadow_inter]
    exact hArithmetic.1
  · intro i j
    have hArithmetic :=
      Omega.Folding.paper_killo_chain_interior_godel_gcd_lcm r (ι i) (ι j)
        (conclusion_screen_rt_chain_arithmetic_divisor_shadow_zero_mem i)
        (conclusion_screen_rt_chain_arithmetic_divisor_shadow_zero_mem j)
    rw [conclusion_screen_rt_chain_arithmetic_divisor_shadow_union]
    exact hArithmetic.2

/-- Paper label: `thm:conclusion-screen-rt-chain-arithmetic-divisor-shadow`. -/
theorem paper_conclusion_screen_rt_chain_arithmetic_divisor_shadow :
    conclusion_screen_rt_chain_arithmetic_divisor_shadow_statement :=
  conclusion_screen_rt_chain_arithmetic_divisor_shadow_verified

end Omega.Conclusion
