import Mathlib.Tactic

namespace Omega.Conclusion

/-- Concrete finite-state package for a circuit fragment generated by deterministic finite-state
gates and a fixed-temperature soft-order gate. The serial and parallel composites are modelled by
finite products, and fanout is recorded as a finite quotient of the parallel state space. -/
structure FixedTempSoftOrderProbabilisticFiniteStateDecidableData where
  detStateCount : ℕ
  softStateCount : ℕ
  leftStateCount : ℕ
  rightStateCount : ℕ
  parallelStateQuotient : ℕ
  reachableDimension : ℕ
  fanoutQuotientBound : parallelStateQuotient ≤ leftStateCount * rightStateCount

namespace FixedTempSoftOrderProbabilisticFiniteStateDecidableData

/-- Serial composition closes the fragment under finite products of deterministic and soft-order
state spaces. -/
abbrev serialStateSpace (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Type :=
  Fin D.detStateCount × Fin D.softStateCount

/-- Parallel composition closes the fragment under finite products of the left and right state
spaces. -/
abbrev parallelStateSpace (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Type :=
  Fin D.leftStateCount × Fin D.rightStateCount

/-- Fanout is captured by a finite quotient whose size is bounded by the ambient parallel product.
-/
abbrev fanoutStateSpace (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Type :=
  Fin D.parallelStateQuotient

/-- Reachable distributions are tested on finitely many coordinates over the decidable coefficient
field `ℚ`. -/
abbrev reachableCoordinateSpace
    (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Type :=
  Fin D.reachableDimension → ℚ

/-- The fixed-temperature fragment stays finite-state under serial, parallel, and fanout
composition. -/
def finiteStateClosure (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Prop :=
  Fintype.card (Fin D.detStateCount × Fin D.softStateCount) = D.detStateCount * D.softStateCount ∧
    Fintype.card (Fin D.leftStateCount × Fin D.rightStateCount) =
      D.leftStateCount * D.rightStateCount ∧
    Fintype.card (Fin D.parallelStateQuotient) = D.parallelStateQuotient ∧
    D.parallelStateQuotient ≤ D.leftStateCount * D.rightStateCount

/-- Distribution equivalence reduces to equality of finitely many reachable `ℚ`-coordinates, so
it is decidable by finite function extensionality. -/
def distributionEquivalenceDecidable
    (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) : Prop :=
  Nonempty (DecidableEq (Fin D.reachableDimension → ℚ))

end FixedTempSoftOrderProbabilisticFiniteStateDecidableData

open FixedTempSoftOrderProbabilisticFiniteStateDecidableData

/-- Paper label: `thm:conclusion-fixed-temp-soft-order-probabilistic-finite-state-decidable`. -/
theorem paper_conclusion_fixed_temp_soft_order_probabilistic_finite_state_decidable
    (D : FixedTempSoftOrderProbabilisticFiniteStateDecidableData) :
    D.finiteStateClosure ∧ D.distributionEquivalenceDecidable := by
  refine ⟨?_, ?_⟩
  · refine ⟨by simp, by simp, by simp, D.fanoutQuotientBound⟩
  · exact ⟨inferInstance⟩

end Omega.Conclusion
