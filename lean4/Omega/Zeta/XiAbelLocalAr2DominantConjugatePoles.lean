import Mathlib.Tactic

namespace Omega.Zeta

/-- The dominant two-pole coefficient contribution generated by two local poles. -/
noncomputable def xi_abel_local_ar2_dominant_conjugate_poles_dominant
    (A α B β : ℂ) (n : ℕ) : ℂ :=
  A * α ^ n + B * β ^ n

/-- The AR(2) residual with characteristic roots `α` and `β`. -/
noncomputable def xi_abel_local_ar2_dominant_conjugate_poles_residual
    (A α B β : ℂ) (n : ℕ) : ℂ :=
  xi_abel_local_ar2_dominant_conjugate_poles_dominant A α B β (n + 2) -
    (α + β) * xi_abel_local_ar2_dominant_conjugate_poles_dominant A α B β (n + 1) +
      α * β * xi_abel_local_ar2_dominant_conjugate_poles_dominant A α B β n

/-- A concrete Cauchy-majorant coefficient for the analytic remainder. -/
noncomputable def xi_abel_local_ar2_dominant_conjugate_poles_cauchyRemainder
    (M R : ℝ) (n : ℕ) : ℝ :=
  M / R ^ n

/-- Concrete statement package for the local two-pole decomposition:
the two dominant pole terms obey their exact AR(2) recurrence, and the analytic remainder
coefficients obey the Cauchy-majorant bound. -/
def paper_xi_abel_local_ar2_dominant_conjugate_poles_statement : Prop :=
  (∀ A α B β : ℂ,
    ∀ n : ℕ, xi_abel_local_ar2_dominant_conjugate_poles_residual A α B β n = 0) ∧
  (∀ M R : ℝ, 0 ≤ M → 1 ≤ R →
    ∀ n : ℕ,
      |xi_abel_local_ar2_dominant_conjugate_poles_cauchyRemainder M R n| ≤ M / R ^ n)

lemma xi_abel_local_ar2_dominant_conjugate_poles_single_root_residual
    (α β x : ℂ) (n : ℕ) (hx : x = α ∨ x = β) :
    x ^ (n + 2) - (α + β) * x ^ (n + 1) + α * β * x ^ n = 0 := by
  rcases hx with rfl | rfl
  · ring_nf
  · ring_nf

/-- Paper label: `thm:xi-abel-local-ar2-dominant-conjugate-poles`. -/
theorem paper_xi_abel_local_ar2_dominant_conjugate_poles :
    paper_xi_abel_local_ar2_dominant_conjugate_poles_statement := by
  refine ⟨?_, ?_⟩
  · intro A α B β n
    unfold xi_abel_local_ar2_dominant_conjugate_poles_residual
      xi_abel_local_ar2_dominant_conjugate_poles_dominant
    have hα :=
      xi_abel_local_ar2_dominant_conjugate_poles_single_root_residual
        α β α n (Or.inl rfl)
    have hβ :=
      xi_abel_local_ar2_dominant_conjugate_poles_single_root_residual
        α β β n (Or.inr rfl)
    linear_combination A * hα + B * hβ
  · intro M R hM hR n
    have hpow_nonneg : 0 ≤ R ^ n := pow_nonneg (le_trans zero_le_one hR) n
    have hterm_nonneg : 0 ≤ M / R ^ n := div_nonneg hM hpow_nonneg
    simp [xi_abel_local_ar2_dominant_conjugate_poles_cauchyRemainder,
      abs_of_nonneg hterm_nonneg]

end Omega.Zeta
