import Mathlib.Tactic

namespace Omega.Zeta

/-- Paper label: `cor:xi-time-part53aa-atomic-ghost-subsemigroup-support`.
An atomic ghost correction formula with an indicator on `ell ∣ n` is equivalent to the displayed
piecewise formula, and in particular the full and core coefficients agree off the subsemigroup
generated by `ell`. -/
theorem paper_xi_time_part53aa_atomic_ghost_subsemigroup_support
    {R : Type*} [Semiring R] (ell m E : ℕ) (u : R) (full core : ℕ → R)
    (xi_time_part53aa_atomic_ghost_subsemigroup_support_atomic_formula :
      ∀ n : ℕ,
        full n =
          core n +
            (if ell ∣ n then (m * ell : R) * u ^ (E * (n / ell)) else 0)) :
    (∀ n : ℕ,
      full n =
        if ell ∣ n then
          core n + (m * ell : R) * u ^ (E * (n / ell))
        else
          core n) ∧
      (∀ n : ℕ, ¬ ell ∣ n → full n = core n) := by
  constructor
  · intro n
    by_cases hn : ell ∣ n
    · simpa [hn] using xi_time_part53aa_atomic_ghost_subsemigroup_support_atomic_formula n
    · simpa [hn] using xi_time_part53aa_atomic_ghost_subsemigroup_support_atomic_formula n
  · intro n hn
    simpa [hn] using xi_time_part53aa_atomic_ghost_subsemigroup_support_atomic_formula n

end Omega.Zeta
