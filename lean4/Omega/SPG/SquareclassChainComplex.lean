import Mathlib.Data.ZMod.Basic
import Mathlib.Tactic

namespace Omega.SPG

abbrev F2 := ZMod 2

/-- `F₂`-chains on a finite basis of oriented cells. -/
abbrev Chain (ι : Type*) := ι → F2

/-- In the paper model, the squareclass group generated by basis primes is identified with the
corresponding `F₂`-vector space of prime exponents. -/
abbrev Squareclass (ι : Type*) := Chain ι

/-- The basis generator corresponding to a single oriented cell. -/
def basisVec {ι : Type*} [DecidableEq ι] (i : ι) : Chain ι := fun j => if j = i then 1 else 0

/-- The squareclass generator attached to one oriented cell. -/
abbrev squareclassGenerator {ι : Type*} [DecidableEq ι] (i : ι) : Squareclass ι := basisVec i

/-- The squareclass encoding is the basis-level identification between chains and prime-exponent
vectors. -/
abbrev squareclassEncode (ι : Type*) : Chain ι ≃+ Squareclass ι :=
  AddEquiv.refl _

/-- The mod-`2` boundary image of a single generator is the indicator of its codimension-one
faces. -/
def boundaryOnGenerator {ι κ : Type*} [DecidableEq κ] (faces : ι → Finset κ) (σ : ι) : Chain κ :=
  fun τ => if τ ∈ faces σ then 1 else 0

/-- The cubical boundary map extended linearly from generators. -/
def cubicalBoundary {ι κ : Type*} [Fintype ι] [DecidableEq κ]
    (faces : ι → Finset κ) : Chain ι → Chain κ := fun c τ =>
  ∑ σ, if τ ∈ faces σ then c σ else 0

/-- The induced squareclass-side boundary homomorphism. -/
abbrev squareclassBoundary {ι κ : Type*} [Fintype ι] [DecidableEq κ]
    (faces : ι → Finset κ) : Squareclass ι → Squareclass κ :=
  cubicalBoundary faces

@[simp] theorem squareclassEncode_basisVec {ι : Type*} [DecidableEq ι] (σ : ι) :
    squareclassEncode ι (basisVec σ) = squareclassGenerator σ :=
  rfl

@[simp] theorem cubicalBoundary_basisVec {ι κ : Type*} [Fintype ι] [DecidableEq ι] [DecidableEq κ]
    (faces : ι → Finset κ) (σ : ι) :
    cubicalBoundary faces (basisVec σ) = boundaryOnGenerator faces σ := by
  ext τ
  classical
  by_cases hτ : τ ∈ faces σ
  · rw [cubicalBoundary, Finset.sum_eq_single σ]
    · simp [basisVec, boundaryOnGenerator, hτ]
    · intro σ' _ hne
      simp [basisVec, boundaryOnGenerator, hτ, hne]
    · simp [basisVec, boundaryOnGenerator, hτ]
  · rw [cubicalBoundary, Finset.sum_eq_zero]
    · simp [boundaryOnGenerator, hτ]
    · intro σ'
      by_cases hτσ' : τ ∈ faces σ'
      · simp [basisVec, hτσ']
        intro hEq
        exact hτ (hEq ▸ hτσ')
      · simp [hτσ']

@[simp] theorem squareclassBoundary_generator {ι κ : Type*} [Fintype ι] [DecidableEq ι]
    [DecidableEq κ] (faces : ι → Finset κ) (σ : ι) :
    squareclassBoundary faces (squareclassGenerator σ) = boundaryOnGenerator faces σ := by
  simpa [squareclassGenerator, squareclassBoundary] using cubicalBoundary_basisVec faces σ

/-- Paper: `thm:spg-dyadic-squareclass-chain-complex`.
The `F₂` chain group and the squareclass group generated by basis primes are identified on
generators, the boundary-side homomorphism is determined by the codimension-one faces of each
generator, and the resulting square commutes with the cubical boundary map. -/
theorem paper_spg_dyadic_squareclass_chain_complex
    {ι κ : Type*} [Fintype ι] [DecidableEq ι] [DecidableEq κ]
    (faces : ι → Finset κ) :
    Function.Bijective (squareclassEncode ι) ∧
      (∀ σ, squareclassEncode ι (basisVec σ) = squareclassGenerator σ) ∧
      (∀ σ, squareclassBoundary faces (squareclassGenerator σ) = boundaryOnGenerator faces σ) ∧
      ∀ c, squareclassEncode κ (cubicalBoundary faces c) =
        squareclassBoundary faces (squareclassEncode ι c) := by
  refine ⟨(squareclassEncode ι).bijective, ?_, ?_, ?_⟩
  · intro σ
    simp
  · intro σ
    simpa using squareclassBoundary_generator faces σ
  · intro c
    rfl

end Omega.SPG
