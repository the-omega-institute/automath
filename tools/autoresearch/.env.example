# Omega Autoresearch — Environment Configuration
#
# Option 1: Direct API key
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://llm.aelf.dev/
#
# Option 2: NyxID managed (recommended)
# No env vars needed — run_overnight.py auto-fetches from nyxid
# Setup: nyxid service add llm-openai --endpoint-url "https://llm.aelf.dev/" --credential-env OPENAI_API_KEY
#
# Option 3: NyxID proxy URL (no key needed)
# OPENAI_BASE_URL=https://nyx-api.chrono-ai.fun/api/v1/proxy/s/llm-openai/
# OPENAI_API_KEY=dummy  # proxy handles auth
#
# For Anthropic:
# ANTHROPIC_API_KEY=sk-ant-your-key-here
